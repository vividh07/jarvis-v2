# JarvisV2 mobile app — copy to .env and fill in your keys
# Expo loads EXPO_PUBLIC_* variables automatically (restart npm start after changes)

EXPO_PUBLIC_WEATHER_API_KEY=your_openweathermap_key_here
EXPO_PUBLIC_WEATHER_CITY=Noida

EXPO_PUBLIC_NEWS_API_KEY=your_newsapi_key_here
EXPO_PUBLIC_NEWS_COUNTRY=in

EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
EXPO_PUBLIC_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
